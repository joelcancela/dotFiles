{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "⚡",
          "foreground": "#ffffff",
          "background": "#ff0000",
          "type": "root",
          "style": "diamond"
        },
        {
          "template": "🦊 {{ .UserName }}",
          "foreground": "#ffffff",
          "background": "#00b1ff",
          "type": "session",
          "style": "diamond"
        },
        {
          "template": "💻 {{ .HostName }}",
          "foreground": "#00b1ff",
          "powerline_symbol": "\ue0b0",
          "background": "#f3e600",
          "type": "session",
          "style": "powerline"
        },
        {
          "template": ".{{ .Name }}",
          "powerline_symbol": "",
          "foreground": "#000000",
          "background": "#f3e600",
          "options": {
            "mapped_shell_names": {
              "pwsh": "ps",
              "bash": "sh"
            }
          },
          "type": "shell",
          "style": "powerline"
        },
        {
          "options": {
            "style": "agnoster_short",
            "max_depth": 2
          },
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#373737",
          "type": "path",
          "style": "powerline"
        },
        {
          "foreground": "#00b1ff",
          "powerline_symbol": "\ue0b0",
          "background": "#f3e600",
          "type": "git",
          "style": "powerline"
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "template": "{{ if .Error }}☢  {{ .Code }}{{ end }}",
          "foreground": "#ffffff",
          "leading_diamond": "",
          "background": "#373737",
          "type": "status",
          "style": "diamond"
        },
        {
          "options": {
            "time_format": "15:04:05"
          },
          "template": "🕖 {{ .CurrentDate | date .Format }}",
          "foreground": "#00b1ff",
          "leading_diamond": "",
          "background": "#000000",
          "type": "time",
          "style": "diamond"
        }
      ]
    }
  ]
}